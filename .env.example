/**
 * 环境配置文件
 * 
 * 根据不同的环境配置 API 基础 URL
 */

// 开发环境
export const development = {
  VITE_API_BASE_URL: 'http://localhost:3000/api',
  VITE_APP_TITLE: '嵌入式系统应用 - 开发环境',
};

// 生产环境
export const production = {
  VITE_API_BASE_URL: '/api',
  VITE_APP_TITLE: '嵌入式系统应用',
};

// 测试环境
export const test = {
  VITE_API_BASE_URL: 'http://test-api.example.com/api',
  VITE_APP_TITLE: '嵌入式系统应用 - 测试环境',
};

// 根据当前环境导出配置
const envConfigs = {
  development,
  production,
  test,
};

const currentEnv = (import.meta.env.MODE || 'development') as keyof typeof envConfigs;

export default envConfigs[currentEnv];
